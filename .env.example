# ModernTensor Environment Configuration Example
# Copy this file to .env and update with your actual values

# Wallet configuration
HOTKEY_BASE_DIR="moderntensor"
COLDKEY_NAME="your_coldkey_name"
HOTKEY_NAME="your_hotkey_name"
HOTKEY_PASSWORD="your_secure_password_here"

# Polkadot Hub (EVM compatible via pallet-revive)
POLKADOT_RPC_URL="https://westend-asset-hub-eth-rpc.polkadot.io"
POLKADOT_CHAIN_ID=420420421
POLKADOT_NETWORK="testnet"  # testnet or mainnet
PRIVATE_KEY="your_private_key_here"

# Alternative Polkadot Hub endpoints
# POLKADOT_RPC_URL="https://testnet-paseo-asset-hub-eth-rpc.polkadot.io"  # Paseo testnet
# POLKADOT_RPC_URL="https://asset-hub-eth-rpc.polkadot.io"  # Mainnet
